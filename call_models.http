


###
# curl -X 'GET'
#  'http://127.0.0.1:4000/v1/models?return_wildcard_routes=true&include_model_access_groups=false&only_model_access_groups=false&include_metadata=false'
#  -H 'accept: application/json'
GET http://127.0.0.1:4000/v1/models?return_wildcard_routes=true&include_model_access_groups=false&only_model_access_groups=false&include_metadata=false
Authorization: Bearer sk-admin-local
Content-Type: application/json
Accept: application/json




### curl -X 'GET'
#  'http://localhost:4000/v1/models?return_wildcard_routes=false&include_model_access_groups=false&only_model_access_groups=false&include_metadata=false'
#  -H 'accept: application/json'
#  -H 'x-litellm-api-key: Bearer sk-admin-local'
GET http://localhost:4000/v1/models?return_wildcard_routes=false&include_model_access_groups=false&only_model_access_groups=false&include_metadata=false
Authorization: Bearer sk-admin-local
Content-Type: application/json
Accept: application/json

